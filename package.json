{
    "name": "hakwa",
    "version": "1.0.0",
    "private": true,
    "description": "An evolving platform",
    "workspaces": [
        "pkg/*",
        "api",
        "apps/*",
        "apps/**"
    ],
    "scripts": {
        "db-push": "npm run push -w @hakwa/db",
        "api-dev": "npm run dev -w @hakwa/api",
        "git-push": "git add . && git commit -m \"Latest_Changes\" && git push",
        "passenger-dev": "npm start -w @hakwa/passenger",
        "merchant-dev": "npm start -w @hakwa/merchant",
        "driver-dev": "npm start -w @hakwa/driver",
        "web-dev": "npm run dev -w @hakwa/web"
    },
    "devDependencies": {
        "typescript": "^5.9.3"
    }
}