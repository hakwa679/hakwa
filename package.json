{
    "name": "hakwa",
    "version": "1.0.0",
    "private": true,
    "description": "An evolving platform",
    "workspaces": [
        "pkg/*",
        "api",
        "apps/*",
        "apps/**"
    ],
    "scripts": {
        "db-push": "npm run push -w @hakwa/db",
        "api-dev": "npm run dev -w @hakwa/api",
        "git-push": "git add . && git commit -m \"Latest_Changes\" && git push",
        "passenger-dev": "npm start -w @hakwa/passenger",
        "merchant-dev": "npm start -w @hakwa/merchant",
        "driver-dev": "npm start -w @hakwa/driver",
        "web-dev": "npm run dev -w @hakwa/web",
        "typecheck:root": "npx tsc --noEmit",
        "typecheck:merchant": "npx tsc --noEmit -p apps/mobile/merchant/tsconfig.json",
        "typecheck:passenger": "npx tsc --noEmit -p apps/mobile/passenger/tsconfig.json",
        "typecheck:driver": "npx tsc --noEmit -p apps/mobile/driver/tsconfig.json",
        "typecheck:web": "npx tsc --noEmit -p apps/web/tsconfig.app.json",
        "typecheck": "npm run typecheck:root && npm run typecheck:merchant && npm run typecheck:passenger && npm run typecheck:driver && npm run typecheck:web"
    },
    "devDependencies": {
        "typescript": "^5.9.3"
    }
}